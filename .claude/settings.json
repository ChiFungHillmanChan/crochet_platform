{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(file:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git worktree:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Read(**)",
      "Edit(src/**)",
      "Edit(lib/**)",
      "Edit(app/**)",
      "Edit(tests/**)",
      "Edit(scripts/**)",
      "Edit(.claude/**)",
      "Edit(test/**)",
      "Edit(spec/**)",
      "Edit(cmd/**)",
      "Edit(pkg/**)",
      "Edit(internal/**)",
      "Edit(server/**)",
      "Edit(api/**)",
      "Edit(services/**)",
      "Edit(models/**)",
      "Edit(views/**)",
      "Edit(controllers/**)",
      "Edit(templates/**)",
      "Edit(public/**)",
      "Edit(config/**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(./secrets/**)",
      "Read(.git/objects/**)",
      "Read(node_modules/**)",
      "Read(dist/**)",
      "Read(build/**)",
      "Read(coverage/**)",
      "Read(__pycache__/**)",
      "Read(.venv/**)",
      "Read(venv/**)",
      "Read(.mypy_cache/**)",
      "Read(.pytest_cache/**)",
      "Read(target/**)",
      "Read(vendor/**)",
      "Read(bin/**)",
      "Read(obj/**)",
      "Read(.gradle/**)",
      "Read(.idea/**)",
      "Read(.vs/**)"
    ],
    "defaultMode": "acceptEdits"
  },
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "16384",
    "BASH_DEFAULT_TIMEOUT_MS": "60000",
    "DISABLE_PROMPT_CACHING": "0",
    "DISABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true
  }
}
